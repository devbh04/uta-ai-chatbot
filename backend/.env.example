# ============================
# North Star AI Chatbot — Environment Configuration
# ============================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === LLM Provider Selection ===
# Options: gemini, azure
LLM_PROVIDER=gemini

# === Azure OpenAI ===
# If using Azure OpenAI, configure these settings
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-01-preview

# === Gemini ===
# API key for Google AI Studio (leave blank if using GCP / Vertex AI)
GEMINI_API_KEY=your-gemini-api-key-here

# === GCP / Vertex AI ===
# If using Vertex AI, specify the path to your service account credentials JSON, GCP project, and location (leave blank if using AI Studio)
GCP_CREDENTIALS_PATH=
GCP_PROJECT=
GCP_LOCATION=us-central1

# === MongoDB ===
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=northstar

# === Qdrant ===
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=products

# === App ===
CORS_ORIGINS=http://localhost:3000
